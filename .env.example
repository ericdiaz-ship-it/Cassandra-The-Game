# CASSANDRA Project - Environment Variables TEMPLATE
# Copy this file to .env and fill in your actual values
# NEVER commit .env to git

# Google Gemini API (for CASSANDRA Chat suspects)
GEMINI_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemma-4-31b-it

# Supabase Configuration (Optional - for session logging)
SUPABASE_URL=your_supabase_url_here
SUPABASE_KEY=your_supabase_anon_key_here

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=cassandra_db
DB_USER=admin
DB_PASSWORD=your_db_password_here

# Authentication Secrets
JWT_SECRET=your_jwt_secret_here
SESSION_SECRET=your_session_secret_here

# External Services
FBI_API_KEY=your_fbi_api_key_here
INTERPOL_API_KEY=your_interpol_api_key_here

# Environment
NODE_ENV=development
DEBUG=false
