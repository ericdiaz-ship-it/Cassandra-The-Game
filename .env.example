# CASSANDRA Project - Environment Variables TEMPLATE
# Copy this file to .env and fill in your actual values
# IMPORTANT: Never commit .env to git - it's in .gitignore

# ─────────────────────────────────────────────────────
# REQUIRED - Google Gemini API
# ─────────────────────────────────────────────────────
# Get your API key from: https://aistudio.google.com/app/apikey
GEMINI_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemma-4-31b-it

# ─────────────────────────────────────────────────────
# OPTIONAL - Supabase Configuration (for session logging)
# ─────────────────────────────────────────────────────
# Get credentials from https://supabase.com
SUPABASE_URL=your_supabase_url_here
SUPABASE_KEY=your_supabase_anon_key_here

# ─────────────────────────────────────────────────────
# Environment Settings
# ─────────────────────────────────────────────────────
NODE_ENV=development
DEBUG=false

# ─────────────────────────────────────────────────────
# Vercel Deployment
# ─────────────────────────────────────────────────────
# When deploying to Vercel, add these variables in:
# Settings → Environment Variables
# Leave DEBUG=false for production

