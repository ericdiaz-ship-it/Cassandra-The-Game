{
  "version": 2,
  "framework": null,
  "buildCommand": "echo 'No build needed for static files'",
  "outputDirectory": ".",
  "env": {
    "GEMINI_KEY": "@gemini_key",
    "GEMINI_MODEL": "@gemini_model",
    "SUPABASE_URL": "@supabase_url",
    "SUPABASE_KEY": "@supabase_key"
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1.js",
      "methods": ["GET", "POST", "PUT", "DELETE"]
    },
    {
      "src": "/(.*)",
      "dest": "/$1",
      "methods": ["GET", "HEAD"]
    }
  ]
}
